# Service Configuration
PORT=3044

# OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434

RUMMY_HOME=~/.rummy

RUMMY_DB_PATH=./rummy.db

# Provider Configuration
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
RUMMY_HTTP_REFERER=https://github.com/possumtech/rummy
# RUMMY_X_TITLE shows your app name in OpenRouter dashboards/rankings
RUMMY_X_TITLE=RUMMY

# Model Aliases (Optional)
RUMMY_MODEL_ccp=deepseek/deepseek-chat

# Model Configuration (Required - no fallbacks)
RUMMY_MODEL_DEFAULT=ccp

# Model Behavior
# LLM temperature (0 = deterministic, 0.7 = creative). Client can override per-request.
RUMMY_TEMPERATURE=0.7

# Context Budget
# Primary: percent of model's context window used for file map (default: 10)
# Budget is derived automatically from the model's context_length.
RUMMY_MAP_MAX_PERCENT=10
# Optional: hard cap in tokens (clamps the percent-derived budget)
# RUMMY_MAP_TOKEN_BUDGET=
# Turns before an agent-promoted file decays back to baseline
RUMMY_DECAY_THRESHOLD=12
# Days to keep completed/aborted runs before purging
RUMMY_RETENTION_DAYS=31

# Timeouts (ms)
RUMMY_RPC_TIMEOUT=10000
RUMMY_FETCH_TIMEOUT=30000
