# Service Configuration
PORT=3044

# OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434

RUMMY_HOME=~/.rummy

# Provider Configuration
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
RUMMY_HTTP_REFERER=https://github.com/possumtech/rummy
# RUMMY_X_TITLE shows your app name in OpenRouter dashboards/rankings
RUMMY_X_TITLE=RUMMY

# Model Aliases (Optional)
RUMMY_MODEL_ccp=deepseek/deepseek-chat-v3

# Model Configuration (Required - no fallbacks)
RUMMY_MODEL_DEFAULT=ccp

# Mapping & Tokenization
# Token budget for the RepoMap perspective
RUMMY_MAP_TOKEN_BUDGET=4096
# Percent of context window to use if contextSize is provided
RUMMY_MAP_MAX_PERCENT=10

# Timeouts (ms)
RUMMY_RPC_TIMEOUT=10000
RUMMY_FETCH_TIMEOUT=30000
