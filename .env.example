# Service Configuration
PORT=3044
# SNORE_HOME defaults to ~/.snore if not set
# SNORE_HOME=/path/to/custom/home

# OPENROUTER_API_KEY is required
# OPENROUTER_API_KEY=

# Provider Configuration
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
SNORE_HTTP_REFERER=https://github.com/possumtech/snore
# SNORE_X_TITLE shows your app name in OpenRouter dashboards/rankings
SNORE_X_TITLE=SNORE

# Model Configuration (Required - no fallbacks)
SNORE_MODEL_DEFAULT=deepseek/deepseek-chat-v3

# Model Aliases (Optional)
# SNORE_MODEL_ccp=deepseek/deepseek-chat-v3

# Mapping & Tokenization
# Token budget for the RepoMap perspective
SNORE_MAP_TOKEN_BUDGET=4096
# Percent of context window to use if contextSize is provided
SNORE_MAP_MAX_PERCENT=10

# Timeouts (ms)
SNORE_RPC_TIMEOUT=10000
SNORE_FETCH_TIMEOUT=30000
