# terminal-bench 2.0 / Harbor configuration — SHARED BASE.
# Loaded by `npm run test:tbench:<profile>` scripts. Each profile then
# overlays `.env.tbench.<profile>` on top of this file. API keys
# (XAI_API_KEY, OPENROUTER_API_KEY, OPENAI_API_KEY) are read from the
# shell, not stored here.

# Local harbor fork checkout (cloned by setup.sh).
RUMMY_TBENCH_HARBOR_DIR=~/repo/harbor/main
RUMMY_TBENCH_HARBOR_REPO=https://github.com/possumtech/harbor.git
RUMMY_TBENCH_HARBOR_REF=add-rummy-agent

# Rummy fetched + installed inside harbor's docker sandbox by the
# rummy adapter's install() step. Pin RUMMY_TBENCH_RUMMY_REF to a
# commit SHA for reproducible eval runs.
RUMMY_TBENCH_RUMMY_REPO=https://github.com/possumtech/rummy.git
RUMMY_TBENCH_RUMMY_REF=test/tbench

# Benchmark target.
RUMMY_TBENCH_DATASET=terminal-bench@2.0

# --- Model alias declarations ---
# Each upstream gets its own alias so the active selection
# (RUMMY_TBENCH_MODEL, set in the per-profile overlay) is unambiguous.
# No commenting/uncommenting required to switch routing.

RUMMY_MODEL_xfast=xai/grok-4-1-fast-non-reasoning
RUMMY_MODEL_xfast_reasoning=xai/grok-4-1-fast-reasoning
RUMMY_MODEL_xfast_or=openrouter/x-ai/grok-4.1-fast
RUMMY_MODEL_gemma=openai/macher.gguf

# Direct xAI auto-discovery of context size returns nothing useful for
# grok-4-fast variants; pin explicitly. xAI documents 2M for
# grok-4-fast-reasoning.
RUMMY_CONTEXT_xfast=2000000
RUMMY_CONTEXT_xfast_reasoning=2000000
RUMMY_CONTEXT_xfast_or=2000000
# Gemma reports its own context size correctly via auto-discovery (32k).

# Per-container memory override (MiB). Empty = use task-declared.
# RUMMY_TBENCH_MEMORY_MB=4096

# --- Active selection + per-model knobs live in the overlay files. ---
# .env.tbench.xfast      — xAI direct, non-reasoning (default sweep target)
# .env.tbench.gemma      — local llama-server via Cloudflare
# .env.tbench.xfast_or   — openrouter routing (leaderboard parity)
# Add a new profile = add a new overlay file + matching `test:tbench:<name>`
# npm script.
