# terminal-bench 2.0 / Harbor configuration.
# Loaded by `npm run test:tbench:*` scripts. OPENROUTER_API_KEY is
# read from your shell (e.g. .bashrc); not stored here.

# Local harbor fork checkout (cloned by setup.sh).
RUMMY_TBENCH_HARBOR_DIR=~/repo/harbor/main
RUMMY_TBENCH_HARBOR_REPO=https://github.com/possumtech/harbor.git
RUMMY_TBENCH_HARBOR_REF=add-rummy-agent

# Rummy fetched + installed inside harbor's docker sandbox by the
# rummy adapter's install() step. Pin RUMMY_TBENCH_RUMMY_REF to a
# commit SHA for reproducible eval runs.
RUMMY_TBENCH_RUMMY_REPO=https://github.com/possumtech/rummy.git
RUMMY_TBENCH_RUMMY_REF=test/tbench

# Benchmark target.
RUMMY_TBENCH_DATASET=terminal-bench@2.0
# Active model — toggle between local gemma and direct xAI grok by
# uncommenting one. Gemma uses OPENAI_BASE_URL from the shell env,
# which points at the Cloudflare-fronted public endpoint
# (https://gemma.possumtech.com) so the harbor docker sandbox can
# reach it.
# RUMMY_TBENCH_MODEL=gemma
RUMMY_TBENCH_MODEL=xfast

# Model aliases — forwarded into the sandbox by the harbor adapter so
# service.js bootstraps them as DB rows at boot. Add additional models
# here as needed.
#
# Analysis runs go direct (xai/...) for clean caching + latency; final
# leaderboard-comparison runs swap to openrouter/... to match the
# tbench leaderboard's upstream. Document the routing in the writeup.
RUMMY_MODEL_xfast=xai/grok-4-1-fast-non-reasoning
# RUMMY_MODEL_xfast=xai/grok-4-1-fast-reasoning
# RUMMY_MODEL_xfast=openrouter/x-ai/grok-4.1-fast

# Direct xAI auto-discovery of context size returns nothing useful for
# grok-4-fast variants; pin explicitly. xAI documents 2M for
# grok-4-fast-reasoning.
RUMMY_CONTEXT_xfast=2000000

RUMMY_THINK=1

# Per-LLM-call ceiling (AbortSignal.timeout in each provider plugin).
# Default 300s (.env.example) is tight for grok-non-reasoning + visible
# `<think>` on hard tbench tasks where the model can think for 3-4 min
# in one call. Bumped to 600s here so a single slow call is recoverable;
# the new TurnExecutor catch translates a fired timeout into a 504 strike
# (one strike = recoverable; MAX_STRIKES=3 = abandon at 499). Harbor's
# per-task budget (RUMMY_LOOP_TIMEOUT, 895-1195s typical) still bounds
# the run end-to-end.
RUMMY_FETCH_TIMEOUT=600000

# Tasks-per-harbor-process. Each task = one docker container, so the
# bound is host CPU/RAM/network. xAI side is non-binding at our key tier
# (1800 RPM, 10M TPM headroom). RAM is the actual ceiling: heavy tasks
# (codegolf compiling C, vim sessions, pytest suites) spike to 1.5-2 GB
# each. 8 keeps a 4 GB buffer on a 20 GB-available machine; raise to
# 10-12 if monitoring shows headroom mid-sweep.
# Cap concurrency at the box's nproc.
RUMMY_TBENCH_CONCURRENCY=24

# Per-container memory override (MiB). Empty = use task-declared.
# RUMMY_TBENCH_MEMORY_MB=4096
