{
	"name": "rummy",
	"version": "0.0.1",
	"description": "Sqlite/Node OpenRouter Engine",
	"keywords": [
		"llm"
	],
	"homepage": "https://github.com/possumtech/rummy#readme",
	"bugs": {
		"url": "https://github.com/possumtech/rummy/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/possumtech/rummy.git"
	},
	"license": "MIT",
	"author": "@wikitopian",
	"engines": {
		"node": ">=25",
		"npm": ">=11"
	},
	"type": "module",
	"main": "service.js",
	"scripts": {
		"start": "node --env-file-if-exists=.env.example --env-file-if-exists=.env service.js",
		"dev": "node --env-file-if-exists=.env.example --env-file-if-exists=.env --env-file-if-exists=.env.dev --watch service.js",
		"debug": "node --env-file-if-exists=.env.example --env-file-if-exists=.env --env-file-if-exists=.env.debug --inspect service.js",
		"lint": "biome check src test migrations --fix --unsafe && npm run lint:sql",
		"lint:sql": ". .venv/bin/activate && sqlfluff lint .",
		"fix:sql": ". .venv/bin/activate && sqlfluff fix . --force",
		"test": "npm run lint && npm run test:all",
		"test:all": "node --env-file-if-exists=.env.example --env-file-if-exists=.env --env-file-if-exists=.env.test --experimental-test-coverage --test-coverage-lines=80 --test-coverage-branches=80 --test-coverage-functions=80 --test-concurrency=1 --test src/**/*.test.js test/integration/**/*.test.js test/e2e/**/*.test.js",
		"test:unit": "node --env-file-if-exists=.env.example --env-file-if-exists=.env --env-file-if-exists=.env.test --test-concurrency=1 --test src/**/*.test.js",
		"test:intg": "node --env-file-if-exists=.env.example --env-file-if-exists=.env --env-file-if-exists=.env.test --test-concurrency=1 --test test/integration/**/*.test.js",
		"test:e2e": "node --env-file-if-exists=.env.example --env-file-if-exists=.env --env-file-if-exists=.env.test --test-concurrency=1 --test test/e2e/**/*.test.js"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6"
	},
	"dependencies": {
		"@possumtech/sqlrite": "^2.0.3",
		"@xmldom/xmldom": "^0.8.11",
		"diff": "^8.0.3",
		"isomorphic-git": "^1.37.4",
		"js-tiktoken": "^1.0.21",
		"parse5": "^8.0.0",
		"tree-sitter": "^0.21.1",
		"tree-sitter-css": "^0.21.0",
		"tree-sitter-html": "^0.23.2",
		"tree-sitter-javascript": "^0.21.4",
		"tree-sitter-typescript": "^0.21.2",
		"ws": "^8.19.0"
	}
}
