{
	"name": "snore",
	"version": "0.0.1",
	"description": "Sqlite/Node OpenRouter Engine",
	"keywords": [
		"llm"
	],
	"homepage": "https://github.com/possumtech/snore#readme",
	"bugs": {
		"url": "https://github.com/possumtech/snore/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/possumtech/snore.git"
	},
	"license": "MIT",
	"author": "@wikitopian",
	"engines": {
		"node": ">=25",
		"npm": ">=11"
	},
	"type": "module",
	"main": "service.js",
	"scripts": {
		"start": "node --env-file-if-exists=.env.example --env-file-if-exists=.env service.js",
		"dev": "node --env-file-if-exists=.env.example --env-file-if-exists=.env --env-file-if-exists=.env.dev --watch service.js",
		"lint": "biome check src test migrations --fix --unsafe && npm run lint:sql",
		"lint:sql": ". .venv/bin/activate && sqlfluff lint .",
		"fix:sql": ". .venv/bin/activate && sqlfluff fix . --force",
		"test": "npm run lint && npm run test:unit && npm run test:intg && npm run test:e2e",
		"test:unit": "node --env-file-if-exists=.env.example --env-file-if-exists=.env --env-file-if-exists=.env.test --test src/**/*.test.js",
		"test:intg": "node --env-file-if-exists=.env.example --env-file-if-exists=.env --env-file-if-exists=.env.test --test test/integration/**/*.test.js",
		"test:e2e": "node --env-file-if-exists=.env.example --env-file-if-exists=.env --env-file-if-exists=.env.test --test test/e2e/**/*.test.js"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6"
	},
	"dependencies": {
		"@possumtech/sqlrite": "^2.0.3",
		"isomorphic-git": "^1.37.4",
		"tree-sitter": "^0.25.0",
		"tree-sitter-css": "^0.25.0",
		"tree-sitter-html": "^0.23.2",
		"tree-sitter-javascript": "^0.25.0",
		"tree-sitter-typescript": "^0.23.2",
		"ws": "^8.19.0"
	}
}
