{
	"$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
	"plugins": ["./biome/no-fallbacks.grit"],
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noStaticOnlyClass": "off"
			}
		}
	},
	"overrides": [
		{
			"includes": ["src/plugins/hedberg/**"],
			"plugins": []
		}
	]
}
