{
	"type": "function",
	"function": {
		"name": "env",
		"description": "Run a read-only shell command to explore the environment (ls, grep, git log, etc).",
		"strict": true,
		"parameters": {
			"type": "object",
			"required": ["command", "reason"],
			"additionalProperties": false,
			"properties": {
				"command": {
					"type": "string",
					"minLength": 1,
					"description": "Shell command to execute (read-only)."
				},
				"reason": {
					"type": "string",
					"minLength": 1,
					"description": "What information this gathers."
				}
			}
		}
	}
}
