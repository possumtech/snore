[sqlfluff]
dialect = sqlite
templater = raw
max_line_length = 100
# AL01, AL02: Explicit AS for aliases
# AM04: Ambiguous column count (SELECT *)
# CV01: No column numbers in GROUP BY/ORDER BY
# JJ01: Explicit JOIN types
# ST06: Explicit join conditions
# LT01: Capitalisation
# LT02: Indentation
# LT05: Leading commas
rules = AL01, AL02, AM04, CV01, JJ01, ST06, LT01, LT02, LT05

[sqlfluff:rules:layout.long_lines]
max_line_length = 100

[sqlfluff:indentation]
indent_unit = tab

[sqlfluff:layout:type:comma]
line_position = leading

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.types]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.functions]
capitalisation_policy = upper
